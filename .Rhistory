# --- FUNCIÓN PARA LEER BANXICO CON CODIFICACIÓN ---
read_banxico_v4 <- function(path, col_name) {
print(paste("Leyendo:", path))
# Leer con codificación ISO-8859-1 (Latin1) que usa Banxico
lines <- read_lines(path, locale = locale(encoding = "ISO-8859-1"))
start_row <- which(grepl("Fecha", lines))[1]
if (is.na(start_row)) stop(paste("No se encontró la celda 'Fecha' en", path))
df <- read_csv(path, skip = start_row - 1, locale = locale(encoding = "ISO-8859-1"), show_col_types = FALSE)
colnames(df)[1:2] <- c("fecha_raw", "valor_raw")
df_clean <- df %>%
mutate(
# Limpiar caracteres extraños en la fecha si los hay
fecha_txt = gsub("[^0-9/]", "", as.character(fecha_raw)),
fecha = dmy(fecha_txt),
valor = as.numeric(valor_raw)
) %>%
filter(!is.na(fecha), !is.na(valor)) %>%
select(fecha, valor)
colnames(df_clean) <- c("fecha", col_name)
return(df_clean)
}
# --- FUNCIÓN PARA LEER BANXICO CON CODIFICACIÓN ---
read_banxico_v4 <- function(path, col_name) {
print(paste("Leyendo:", path))
# Leer con codificación ISO-8859-1 (Latin1) que usa Banxico
lines <- read_lines(path, locale = locale(encoding = "ISO-8859-1"))
start_row <- which(grepl("Fecha", lines))[1]
if (is.na(start_row)) stop(paste("No se encontró la celda 'Fecha' en", path))
df <- read_csv(path, skip = start_row - 1, locale = locale(encoding = "ISO-8859-1"), show_col_types = FALSE)
colnames(df)[1:2] <- c("fecha_raw", "valor_raw")
df_clean <- df %>%
mutate(
# Limpiar caracteres extraños en la fecha si los hay
fecha_txt = gsub("[^0-9/]", "", as.character(fecha_raw)),
fecha = dmy(fecha_txt),
valor = as.numeric(valor_raw)
) %>%
filter(!is.na(fecha), !is.na(valor)) %>%
select(fecha, valor)
colnames(df_clean) <- c("fecha", col_name)
return(df_clean)
}
# --- PROCESAMIENTO ---
tryCatch({
# 1. BANXICO
fix <- read_banxico_v4("input/tc_fix.csv", "tc_fix")
nominal <- read_banxico_v4("input/tasa_nominal.csv", "tasa_nominal")
inpc_df <- read_banxico_v4("input/inflacion.csv", "inpc")
banxico_data <- inpc_df %>%
mutate(fecha_m = floor_date(fecha, "month")) %>%
arrange(fecha_m) %>%
mutate(inf_mensual = (inpc / lag(inpc) - 1) * 100) %>%
inner_join(mutate(nominal, fecha_m = floor_date(fecha, "month")), by = "fecha_m") %>%
inner_join(mutate(fix, fecha_m = floor_date(fecha, "month")), by = "fecha_m") %>%
mutate(
inf_anualizada = ((1 + inf_mensual/100)^12 - 1) * 100,
tasa_real = tasa_nominal - inf_anualizada
) %>%
mutate(year = year(fecha_m), trimestre = quarter(fecha_m)) %>%
group_by(year, trimestre) %>%
summarise(
tc_fix = mean(tc_fix, na.rm = TRUE),
tasa_real = mean(tasa_real, na.rm = TRUE),
.groups = "drop"
)
# 2. INEGI
print("Leyendo: input/inegi_consumo.csv")
# El archivo de INEGI es UTF-16LE
df_inegi_raw <- read_lines("input/inegi_consumo.csv", locale = locale(encoding = "UTF-16LE"))
start_inegi <- which(grepl("Periodo", df_inegi_raw))[1]
df_inegi <- read_csv("input/inegi_consumo.csv", skip = start_inegi - 1,
locale = locale(encoding = "UTF-16LE"), show_col_types = FALSE)
colnames(df_inegi)[1:4] <- c("periodo", "c_total", "c_nacional", "c_importado")
df_inegi_limpio <- df_inegi %>%
filter(!is.na(c_total)) %>%
mutate(
year = as.numeric(substr(periodo, 1, 4)),
trimestre = as.numeric(substr(periodo, 6, 7))
)
# 3. UNIÓN FINAL
df_final <- df_inegi_limpio %>%
inner_join(banxico_data, by = c("year", "trimestre")) %>%
select(year, trimestre, periodo, c_total, c_nacional, c_importado, tc_fix, tasa_real) %>%
arrange(year, trimestre)
write_csv(df_final, "output/consumo_limpio.csv")
print("¡Éxito! Archivo 'output/consumo_limpio.csv' generado.")
print(head(df_final))
}, error = function(e) {
print(paste("Ha ocurrido un error:", e$message))
})
