# Cargar librerías
if (!require("readr")) install.packages("readr")
if (!require("dplyr")) install.packages("dplyr")
if (!require("tidyr")) install.packages("tidyr")
if (!require("lubridate")) install.packages("lubridate")
library(readr)
library(dplyr)
library(tidyr)
library(lubridate)
# Crear carpeta output si no existe
if (!dir.exists("output")) dir.create("output")
# --- 1. FUNCIÓN PARA LEER BANXICO (FORMATO HORIZONTAL) ---
read_banxico_horizontal <- function(path, col_name) {
# Leer el archivo omitiendo las líneas de metadatos (típicamente las primeras 17)
# Buscamos la línea que empieza con "Serie" o "Fecha"
raw_data <- read_lines(path)
start_line <- which(grepl("Serie", raw_data))[1]
# Leer solo la fila de fechas y la fila de datos
df_raw <- read_csv(path, skip = start_line - 1, show_col_types = FALSE)
# Pivotar de horizontal a vertical
df_long <- df_raw %>%
pivot_longer(cols = -c(1:9), names_to = "fecha", values_to = "valor") %>%
mutate(
fecha = dmy(fecha),
valor = as.numeric(valor)
) %>%
filter(!is.na(valor)) %>%
select(fecha, valor)
colnames(df_long) <- c("fecha", col_name)
return(df_long)
}
# --- 2. PROCESAR BANXICO ---
print("Procesando datos de BANXICO...")
fix <- read_banxico_horizontal("input/tc_fix.csv", "tc_fix")
source("~/Tarea 2 Macroeconomia/05_01_limpieza_consumo.R", echo = TRUE)
